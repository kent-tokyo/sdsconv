  "FireFightingMeasures": {
    "FireFightingProcedures": {
      "FullText": "安全に対処できるならば着火源を除去すること。危険でなければ火災区域から容器を移動する。容器が熱に晒されているときは、移さない。"
    },
    "MediaToBeUsed": {
      "FullText": "泡消火剤、粉末消火剤、二酸化炭素、乾燥砂"
    },
    "SpecialProtectiveEquipmentForFirefighters": {
      "FullText": "適切な空気呼吸器、防護服（耐熱性）を着用する。"
    }
  },
  "FirstAidMeasures": {
    "ExposureRoute": {
      "FirstAidEye": {
        "FullText": "水で数分間注意深く洗うこと。次に、コンタクトレンズを着用していて容易に外せる場合は外すこと。その後も洗浄を続けること。直ちに医師に連絡すること。"
      },
      "FirstAidIngestion": {
        "FullText": "口をすすぐこと。無理に吐かせないこと。気分が悪い時は医師に連絡すること。"
      },
      "FirstAidInhalation": {
        "FullText": "被災者を新鮮な空気のある場所に移動し、呼吸しやすい姿勢で休息させること。気分が悪い時は医師に連絡すること。"
      },
      "FirstAidSkin": {
        "FullText": "直ちに、汚染された衣類をすべて脱ぐこと、又は取り去ること。皮膚を流水またはシャワーで洗うこと。多量の水と石鹸で洗うこと。皮膚刺激または発疹が生じた場合、医師の診断、手当てを受けること。汚染された衣類を再使用する前に洗濯すること。"
      }
    }
  },
  "HandlingAndStorage": {
    "SafeHandling": {
      "HandlingPrecautions": "すべての発火源を速やかに取除く（近傍での喫煙、火花や火炎の禁止）。この物質を貯蔵ないし取扱う作業場には洗眼器と安全シャワーを設置すること。取扱い後はよく手を洗うこと。",
      "TechnicalMeasuresAndStorageConditions": {
        "ProtectiveMeasures": "ばく露を防止するため、装置の密閉化又は局所排気装置を設置すること。『8．ばく露防止及び保護措置』に記載の設備対策を行い、保護具を着用する。",
        "VentilationCondition": "『8．ばく露防止及び保護措置』に記載の局所排気、全体換気を行う。"
      }
    },
    "Storage": {
      "ConditionsForSafeStorage": {
        "TechnicalMeasuresAndStorageConditions": "容器を密閉して換気の良い場所で保管すること。施錠して保管すること。"
      }
    }
  },
