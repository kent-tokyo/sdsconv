{
  "AccidentalReleaseMeasures": {
    "ContainmentAndCleaningUp": {
      "FullText": "清除所有点火源(禁止现场有吸烟、火花或火焰)。不可接触泄漏物或在其中走动。用水濡湿并构筑防护围栏，之后进行废弃处置。泄漏物用洁净的铁铲装入清洁干燥的容器中，缓缓盖上后再从泄漏场所移走。"
    },
    "EnvironmentalPrecautions": {
      "FullText": "防止流入排水沟、下水道、地下室或封闭场所。"
    },
    "HumanExposureAndEmergencyMeasuress": {
      "FullText": "将受害人转移到空气新鲜处，使其保暖并保持安静。呼叫救护车。呼吸停止时应进行人工呼吸。脱掉沾染的衣服和鞋子并进行隔离。如接触到泄漏物，立即用流动清水清洗皮肤或眼睛至少15分钟。如需清除附着在皮肤上固体熔融物，应请求医生帮助。应确保医生了解暴露物质名称，并采取防护措施。"
    }
  },
