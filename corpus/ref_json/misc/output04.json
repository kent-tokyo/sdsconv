  "FireFightingMeasures": {
    "FireFightingProcedures": {
      "FullText": "小型火灾：使用干式化学灭火剂、二氧化碳、沙、土壤、酒水、一般泡沫灭火剂。\n大型火灾：使用酒水或一般泡沫灭火剂。\n若无危险，移走容器离开火灾区域。"
    },
    "MediaToBeUsed": {
      "FullText": "干式化学灭火剂、二氧化碳、沙、土壤、酒水、一般泡沫灭火剂。"
    }
  },
  "FirstAidMeasures": {
    "ExposureRoute": {
      "FirstAidEye": {
        "FullText": "用水小心冲洗眼睛至少15分钟以上。如戴隐形眼镜并可方便地取出，取出隐形眼镜。继续冲洗。如仍觉眼刺激，求医/就诊。"
      },
      "FirstAidIngestion": {
        "FullText": "漱口。如误吞咽，立即求医/就诊。"
      },
      "FirstAidInhalation": {
        "FullText": "将受害人转移到空气新鲜处，尽量保持安静并使其保暖，保持呼吸舒适的休息姿势。如感觉不适，呼叫解毒中心或医生。"
      },
      "FirstAidSkin": {
        "FullText": "立即用大量肥皂和水冲洗至少15分钟。如发生皮肤刺激，呼叫解毒中心或医生。脱掉沾染的衣服和鞋子并进行隔离。"
      }
    }
  },
  "HandlingAndStorage": {
    "SafeHandling": {
      "HandlingPrecautions": "不可置于热源附近，不可靠近火花、火焰。迅速清除操作场所附近能成为点火源的物品。禁止使容器翻倒、坠落、受撞击或采取拖拽等粗暴的方式操作处置。避免泄漏、溢漏或飞散等，不可随意让粉尘和蒸气产生。在设有局部排气装置的场所进行作业。作业后彻底清洗手部、脸部。佩戴适当的防护装置，避免接触皮肤。防止进入眼睛。避开日光直射和含紫外线的光源。在黄光灯下进行操作处置。",
      "TechnicalMeasuresAndStorageConditions": {
        "ProtectiveMeasures": "在设有局部排气装置的场所进行作业。"
      }
    },
    "Storage": {
      "ConditionsForSafeStorage": {
        "TechnicalMeasuresAndStorageConditions": "密闭容器，保管在阴冷场所(10℃以下)。0℃以下保管时应采取防止结露的措施。存放处须加锁。"
      }
    }
  },
